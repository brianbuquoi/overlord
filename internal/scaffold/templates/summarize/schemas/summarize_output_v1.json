{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "summarize.output",
  "description": "Intermediate summary emitted by the summarize stage.",
  "type": "object",
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "word_count": {
      "type": "integer",
      "minimum": 0
    }
  },
  "required": ["summary", "word_count"],
  "additionalProperties": false
}
