{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "summarize.validate.output",
  "description": "Final validated summary payload emitted by the validate stage.",
  "type": "object",
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "valid": {
      "type": "boolean"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": ["summary", "valid", "issues"],
  "additionalProperties": false
}
