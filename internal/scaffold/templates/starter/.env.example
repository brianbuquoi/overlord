# overlord init does NOT auto-source this file. Copy it to `.env` and load
# it yourself (e.g. `set -a; source .env; set +a`) before running against a
# real provider. Uncomment the line for whichever provider you pick and
# replace the placeholder.
#
# The placeholders below are deliberately NOT real-looking keys — they do
# not start with provider prefixes like `sk-` so secret scanners
# (gitleaks, GitHub push protection) will not greenlight an accidental
# commit of this file unchanged.

# ANTHROPIC_API_KEY=REPLACE_ME_NOT_A_REAL_KEY
# OPENAI_API_KEY=REPLACE_ME_NOT_A_REAL_KEY
# GEMINI_API_KEY=REPLACE_ME_NOT_A_REAL_KEY

# For Ollama (self-hosted), set the endpoint instead of an API key:
# OLLAMA_ENDPOINT=http://localhost:11434
