# overlord init does NOT auto-source this file. Copy it to `.env` and load it
# yourself (e.g. `set -a; source .env; set +a`) before running against a
# real provider. The placeholder below is deliberately NOT a real-looking
# Anthropic key — it does not start with `sk-` so secret scanners
# (gitleaks, GitHub push protection) will not greenlight an accidental
# commit of this file unchanged.
ANTHROPIC_API_KEY=REPLACE_ME_NOT_A_REAL_KEY
